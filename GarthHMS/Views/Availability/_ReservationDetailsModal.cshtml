@* GarthHMS.Web/Views/Availability/_ReservationDetailsModal.cshtml *@
@model GarthHMS.Core.DTOs.Reservation.ReservationDetailDto

@{
    var isCancelled = Model.Status == "cancelled";
    var isCheckedOut = Model.Status == "checked_out";
    var isDraft = Model.Status == "draft";
    var isReadOnly = isCancelled || isCheckedOut;

    var headerColor = Model.Status switch
    {
        "cancelled" => "#A32D2D",
        "checked_out" => "#444441",
        "draft" => "#854F0B",
        "confirmed" => "#2BA49A",
        "checked_in" => "#185FA5",
        _ => "#2BA49A"
    };

    var statusBadgeClass = Model.Status switch
    {
        "pending" => "bg-warning text-dark",
        "confirmed" => "bg-success",
        "checked_in" => "bg-info",
        "checked_out" => "bg-secondary",
        "cancelled" => "bg-danger",
        "draft" => "bg-warning text-dark",
        "no_show" => "bg-secondary",
        _ => "bg-secondary"
    };

    // Extraer motivo de cancelación de internal_notes
    string? cancelReason = null;
    if (isCancelled && !string.IsNullOrEmpty(Model.InternalNotes))
    {
        var match = System.Text.RegularExpressions.Regex.Match(
            Model.InternalNotes, @"\[CANCELADO\] (.+)");
        if (match.Success)
            cancelReason = match.Groups[1].Value.Trim();
    }

    // Iniciales del huésped
    var initials = "";
    if (!string.IsNullOrEmpty(Model.GuestFirstName))
        initials += Model.GuestFirstName[0];
    if (!string.IsNullOrEmpty(Model.GuestLastName))
        initials += Model.GuestLastName[0];
}

<style>
    .rd-header {
        margin: -1rem -1rem 0 -1rem;
        padding: 1rem 1.25rem;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-radius: 6px 6px 0 0;
    }

    .rd-folio {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        font-family: 'Courier New', monospace;
    }

    .rd-cancel-banner {
        background: #FCEBEB;
        border-left: 4px solid #E24B4A;
        padding: 0.75rem 1rem;
        margin: 0.75rem 0;
        border-radius: 0 6px 6px 0;
        font-size: 0.85rem;
        color: #7F1D1D;
    }

    .rd-section-title {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-secondary);
        padding: 0.75rem 0 0.35rem;
        border-top: 1px solid var(--border-color);
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .rd-guest-row {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.5rem 0;
    }

    .rd-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .rd-kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.5rem;
        margin: 0.5rem 0;
    }

    .rd-kpi {
        background: var(--bg-surface-alt);
        border-radius: 6px;
        padding: 0.5rem 0.65rem;
    }

    .rd-kpi-label {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-secondary);
        margin-bottom: 2px;
    }

    .rd-kpi-value {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--text-primary);
    }

    .rd-room-card {
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 0.65rem 0.85rem;
        margin-bottom: 0.5rem;
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
    }

    .rd-room-num {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        flex-shrink: 0;
        background: rgba(43,164,154,.12);
        color: #2BA49A;
    }

    .rd-fin-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.84rem;
        padding: 2px 0;
        color: var(--text-secondary);
    }

        .rd-fin-row.total {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-primary);
            border-top: 2px solid var(--border-color);
            margin-top: 0.35rem;
            padding-top: 0.5rem;
        }

    .rd-deposit-box {
        border-radius: 6px;
        padding: 0.6rem 0.85rem;
        margin-top: 0.5rem;
        font-size: 0.83rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .rd-deposit-paid {
        background: rgba(56,161,105,.1);
        color: #276749;
        border: 1px solid rgba(56,161,105,.25);
    }

    .rd-deposit-pending {
        background: rgba(214,158,46,.1);
        color: #7B5E05;
        border: 1px solid rgba(214,158,46,.25);
    }

    .rd-deposit-retained {
        background: rgba(229,62,62,.08);
        color: #9B2C2C;
        border: 1px solid rgba(229,62,62,.2);
    }

    .rd-note-box {
        background: var(--bg-surface-alt);
        border-radius: 6px;
        padding: 0.6rem 0.85rem;
        font-size: 0.82rem;
        color: var(--text-secondary);
        font-style: italic;
        margin-top: 0.35rem;
    }

    .rd-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1rem;
        padding-top: 0.75rem;
        border-top: 1px solid var(--border-color);
    }

    .rd-header-clean {
        margin-bottom: 0.75rem;
    }

    .rd-title-main {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.4rem;
    }

    .rd-status-bar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        font-size: 0.8rem;
    }

        .rd-status-bar .badge {
            font-size: 0.7rem;
            padding: 0.3rem 0.55rem;
        }

    .rd-folio {
        font-family: 'Courier New', monospace;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: var(--text-primary);
    }

    .rd-meta {
        color: var(--text-secondary);
        margin-left: auto;
        font-size: 0.75rem;
    }

    .rd-vip {
        background: rgba(245,158,11,.15);
        color: #b45309;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.7rem;
    }




</style>

<div class="text-start">

    @* ── HEADER COLOREADO ── *@
    <div class="rd-header-clean">

        <div class="rd-title-main">
            @(isDraft ? "Reserva en borrador" : "Detalle de reserva")
        </div>

        <div class="rd-status-bar">

            <span class="badge @statusBadgeClass">
                @Model.StatusLabel
            </span>

            <span class="rd-folio">@Model.Folio</span>

            @if (Model.GuestIsVip)
            {
                <span class="rd-vip">
                    <i class="fas fa-star fa-xs me-1"></i>VIP
                </span>
            }

            <span class="rd-meta">
                @Model.SourceLabel
            </span>

        </div>
    </div>
    @* ── BANNER CANCELACIÓN ── *@
    @if (isCancelled)
    {
        <div class="rd-cancel-banner">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Reserva cancelada</strong>
            @if (!string.IsNullOrEmpty(cancelReason))
            {
                <div class="mt-1" style="font-size:0.8rem;">Motivo: @cancelReason</div>
            }
        </div>
    }

    @* ── HUÉSPED ── *@
    <div class="rd-section-title">
        <i class="fas fa-user fa-xs"></i> Huésped
    </div>
    <div class="rd-guest-row">
        <div class="rd-avatar" style="background:@(isCancelled ? "rgba(229,62,62,.12)" : "rgba(43,164,154,.12)");
                                      color:@(isCancelled ? "#C53030" : "#2BA49A")">
            @initials.ToUpper()
        </div>
        <div>
            <div style="font-size:1rem;font-weight:700;color:var(--text-primary);">
                @Model.GuestFullName
            </div>
            <div style="font-size:0.82rem;color:var(--text-secondary);">
                @if (!string.IsNullOrEmpty(Model.GuestPhone))
                {
                    <i class="fas fa-phone fa-xs me-1"></i>

                    @Model.GuestPhone
                }
                @if (!string.IsNullOrEmpty(Model.GuestEmail))
                {
                    <span class="ms-2"><i class="fas fa-envelope fa-xs me-1"></i>@Model.GuestEmail</span>
                }
            </div>
        </div>
    </div>

    @* ── ESTANCIA ── *@
    <div class="rd-section-title">
        <i class="fas fa-calendar-alt fa-xs"></i> Estancia
        @if (isReadOnly)
        {
            <span style="font-size:0.65rem;color:var(--text-secondary);font-weight:400;">(no activa)</span>
        }
    </div>
    <div class="rd-kpi-grid" style="@(isReadOnly ? "opacity:.65;" : "")">
        <div class="rd-kpi">
            <div class="rd-kpi-label">Check-in</div>
            <div class="rd-kpi-value">@Model.CheckInDate.ToString("dd MMM")</div>
        </div>
        <div class="rd-kpi">
            <div class="rd-kpi-label">Check-out</div>
            <div class="rd-kpi-value">@Model.CheckOutDate.ToString("dd MMM")</div>
        </div>
        <div class="rd-kpi">
            <div class="rd-kpi-label">Noches</div>
            <div class="rd-kpi-value" style="color:#2BA49A">@Model.NumNights</div>
        </div>
        <div class="rd-kpi">
            <div class="rd-kpi-label">Motivo</div>
            <div class="rd-kpi-value">@(string.IsNullOrEmpty(Model.TravelReasonLabel) ? "—" : Model.TravelReasonLabel)</div>
        </div>
    </div>

    @* ── HABITACIONES ── *@
    @if (Model.Rooms?.Any() == true)
    {
        <div class="rd-section-title">
            <i class="fas fa-bed fa-xs"></i> Habitaciones (@Model.Rooms.Count)
        </div>
        @foreach (var room in Model.Rooms)
        {
            <div class="rd-room-card" style="@(isReadOnly ? "opacity:.7;" : "")">
                <div class="rd-room-num">@room.RoomNumber</div>
                <div style="flex:1;">
                    <div style="font-size:0.88rem;font-weight:700;color:var(--text-primary);">
                        @room.RoomTypeName
                        <span style="font-size:0.75rem;font-weight:400;color:var(--text-secondary);">· @room.RoomTypeCode</span>
                    </div>
                    <div style="font-size:0.78rem;color:var(--text-secondary);margin-top:2px;display:flex;gap:0.65rem;flex-wrap:wrap;">
                        @if (room.Floor.HasValue)
                        {
                            <span><i class="fas fa-layer-group fa-xs me-1"></i>Piso @room.Floor</span>
                        }
                        <span><i class="fas fa-user fa-xs me-1"></i>@room.NumAdults adulto@(room.NumAdults != 1 ? "s" : "")</span>
                        @if (room.NumChildren > 0)
                        {
                            <span><i class="fas fa-child fa-xs me-1"></i>@room.NumChildren niño@(room.NumChildren != 1 ? "s" : "")</span>
                        }
                        @if (room.NumBabies > 0)
                        {
                            <span><i class="fas fa-baby fa-xs me-1"></i>@room.NumBabies bebé@(room.NumBabies != 1 ? "s" : "")</span>
                        }
                        @if (room.HasPets)
                        {
                            <span class="badge" style="background:rgba(43,164,154,.12);color:#2BA49A;font-size:0.65rem;">
                                <i class="fas fa-paw me-1"></i>@room.NumPets mascota@(room.NumPets != 1 ? "s" : "")
                            </span>
                        }
                        @if (room.ExtraPersonCharge > 0)
                        {
                            <span class="badge" style="background:rgba(214,158,46,.12);color:#7B5E05;font-size:0.65rem;">
                                +$@room.ExtraPersonCharge.ToString("N0") p.extra
                            </span>
                        }
                    </div>
                </div>
                <div style="font-size:0.85rem;font-weight:700;color:var(--text-primary);white-space:nowrap;">
                    $@room.PricePerNight.ToString("N0")<span style="font-size:0.7rem;font-weight:400;color:var(--text-secondary);">/noche</span>
                </div>
            </div>
        }
    }

    @* ── FINANCIERO ── *@
    <div class="rd-section-title">
        <i class="fas fa-dollar-sign fa-xs"></i> Financiero
    </div>
    <div style="@(isReadOnly ? "opacity:.8;" : "")">
        @if (Model.Subtotal != Model.Total)
        {
            <div class="rd-fin-row"><span>Subtotal</span><span>$@Model.Subtotal.ToString("N2")</span></div>
        }
        @if (Model.DiscountAmount > 0)
        {
            <div class="rd-fin-row" style="color:var(--success);">
                <span><i class="fas fa-tag fa-xs me-1"></i>Descuento</span>
                <span>-$@Model.DiscountAmount.ToString("N2")</span>
            </div>
        }
        @if (Model.TaxesAmount > 0)
        {
            <div class="rd-fin-row"><span>Impuestos</span><span>$@Model.TaxesAmount.ToString("N2")</span></div>
        }
        <div class="rd-fin-row total">
            <span>Total</span>
            <span style="color:var(--primary);">$@Model.Total.ToString("N2") MXN</span>
        </div>

        @* Pagos registrados *@
        @if (Model.Payments?.Any() == true)
        {
            <div class="rd-deposit-box rd-deposit-paid" style="flex-direction:column;align-items:flex-start;gap:0.4rem;">
                <div style="font-size:0.78rem;font-weight:700;color:#276749;margin-bottom:2px;">
                    <i class="fas fa-check-circle me-1"></i>Pagos registrados
                </div>
                @foreach (var p in Model.Payments)
                {
                    <div class="d-flex justify-content-between w-100" style="font-size:0.82rem;">
                        <span>
                            <span class="badge" style="background:rgba(56,161,105,.15);color:#276749;font-size:0.7rem;">
                                @p.MethodLabel
                            </span>
                            @if (!string.IsNullOrEmpty(p.Reference))
                            {
                                <span class="text-muted ms-1" style="font-size:0.75rem;">Ref: @p.Reference</span>
                            }
                            <span class="text-muted ms-1" style="font-size:0.72rem;">
                                · @p.PaymentDate.ToLocalTime().ToString("dd MMM HH:mm")
                            </span>
                        </span>
                        <strong>$@p.Amount.ToString("N2")</strong>
                    </div>
                }
                @if (Model.Payments.Count > 1)
                {
                    <div class="d-flex justify-content-between w-100 pt-1"
                         style="border-top:1px dashed rgba(56,161,105,.3);font-size:0.83rem;">
                        <span style="color:#276749;">Total pagado</span>
                        <strong style="color:#276749;">
                            $@Model.Payments.Sum(p => p.Amount).ToString("N2")
                        </strong>
                    </div>
                }
            </div>
        }
        else if (!isCancelled)
        {
            <div class="rd-deposit-box rd-deposit-pending">
                <i class="fas fa-clock"></i>
                <span>
                    Anticipo pendiente
                    @if (Model.DepositAmount > 0)
                    {
                        <strong> $@Model.DepositAmount.ToString("N2")</strong>
                    }
                    @if (Model.DepositDueDate.HasValue)
                    {
                        <span class="ms-1">· Vence @Model.DepositDueDate.Value.ToString("dd MMM")</span>
                    }
                </span>
            </div>
        }
        else if (isCancelled && Model.DepositAmount > 0)
        {
            <div class="rd-deposit-box rd-deposit-retained">
                <i class="fas fa-times-circle"></i>
                <span>
                    Anticipo <strong>$@Model.DepositAmount.ToString("N2")</strong>
                    — retenido por política del hotel
                </span>
            </div>
        }

        @if (Model.BalancePending > 0 && !isCancelled)
        {
            <div class="rd-fin-row" style="margin-top:0.35rem;font-weight:600;">
                <span>Saldo pendiente</span>
                <span style="color:var(--danger);">$@Model.BalancePending.ToString("N2")</span>
            </div>
        }
    </div>

    @* ── NOTAS ── *@
    @if (!string.IsNullOrWhiteSpace(Model.GuestNotes))
    {
        <div class="rd-section-title">
            <i class="fas fa-comment fa-xs"></i> Notas del huésped
        </div>
        <div class="rd-note-box">@Model.GuestNotes</div>
    }

    @* ── FOOTER ── *@
    <div class="rd-footer">
        <div style="font-size:0.78rem;color:var(--text-secondary);">
            Creada @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-secondary" onclick="Swal.close()">
                Cerrar
            </button>
            @if (!isReadOnly)
            {
                <button class="btn btn-sm btn-primary"
                        onclick="Swal.close(); showInfoToast('Vista completa disponible próximamente')">
                    <i class="fas fa-external-link-alt me-1"></i>Ver / Editar completo
                </button>
            }
        </div>
    </div>

</div>