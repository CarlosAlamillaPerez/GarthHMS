@* GarthHMS.Web/Views/Availability/_ReservationDetailsModal.cshtml *@
@model GarthHMS.Core.DTOs.AvailabilityEngine.ReservationListItemDto

<div class="text-start">

    @* Folio + Estado *@
    <div class="d-flex align-items-center gap-2 mb-3">
        <span class="badge fs-6 bg-primary">@Model.Folio</span>
        @{
            var badgeClass = Model.Status?.ToLower() switch
            {
                "pending" => "bg-warning text-dark",
                "confirmed" => "bg-success",
                "checked_in" => "bg-info",
                "checked_out" => "bg-secondary",
                "cancelled" => "bg-danger",
                _ => "bg-secondary"
            };
        }
        <span class="badge @badgeClass">@Model.StatusLabel</span>
        @if (Model.IsVip)
        {
            <span class="badge" style="background:rgba(245,158,11,.2);color:#d97706;">
                <i class="fas fa-star fa-xs me-1"></i>VIP
            </span>
        }
    </div>

    @* Huésped *@
    <div class="mb-3 p-3 rounded" style="background:var(--bg-surface-alt);">
        <div class="fw-bold text-primary mb-1">
            <i class="fas fa-user-circle me-2"></i>@Model.GuestFullName
        </div>
        @if (!string.IsNullOrEmpty(Model.GuestPhone))
        {
            <div class="small text-muted">
                <i class="fas fa-phone fa-xs me-1"></i>@Model.GuestPhone
            </div>
        }
    </div>

    @* Fechas y habitaciones *@
    <div class="row g-2 mb-3">
        <div class="col-6">
            <div class="small text-muted fw-semibold mb-1">CHECK-IN</div>
            <div class="fw-bold">@Model.CheckInDate.ToString("dd MMM yyyy")</div>
        </div>
        <div class="col-6">
            <div class="small text-muted fw-semibold mb-1">CHECK-OUT</div>
            <div class="fw-bold">@Model.CheckOutDate.ToString("dd MMM yyyy")</div>
        </div>
        @if (Model.NumNights.HasValue)
        {
            <div class="col-6">
                <div class="small text-muted fw-semibold mb-1">NOCHES</div>
                <div class="fw-bold">@Model.NumNights</div>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.RoomsSummary))
        {
            <div class="col-6">
                <div class="small text-muted fw-semibold mb-1">HABITACIÓN(ES)</div>
                <div class="fw-bold">@Model.RoomsSummary</div>
            </div>
        }
    </div>

    @* Canal *@
    <div class="mb-3">
        <div class="small text-muted fw-semibold mb-1">CANAL DE ORIGEN</div>
        <span class="badge bg-secondary">@Model.SourceLabel</span>
    </div>

    <hr class="my-3">

    @* Financiero *@
    <div class="row g-2">
        <div class="col-6">
            <div class="small text-muted fw-semibold mb-1">TOTAL</div>
            <div class="fw-bold fs-5 text-primary">$@Model.Total.ToString("N0") MXN</div>
        </div>
        <div class="col-6">
            <div class="small text-muted fw-semibold mb-1">ANTICIPO</div>
            @if (Model.HasDeposit)
            {
                <div class="fw-bold text-success">
                    <i class="fas fa-check-circle fa-xs me-1"></i>$@Model.DepositAmount.ToString("N0")
                </div>
            }
            else
            {
                <div class="text-warning fw-bold">
                    <i class="fas fa-clock fa-xs me-1"></i>Pendiente
                </div>
            }
        </div>
        @if (Model.BalancePending > 0)
        {
            <div class="col-12">
                <div class="small text-muted fw-semibold mb-1">SALDO PENDIENTE</div>
                <div class="fw-bold text-danger">$@Model.BalancePending.ToString("N0") MXN</div>
            </div>
        }
    </div>

    <div class="mt-3 small text-muted fst-italic">
        <i class="fas fa-info-circle me-1"></i>
        El detalle completo estará disponible en el módulo de Reservas (Componente 3).
    </div>
</div>
