@* GarthHMS.Web/Views/Reservations/_ReservationDetailsModal.cshtml *@
@model GarthHMS.Core.DTOs.Reservation.ReservationDetailDto

@{
    var statusColors = new Dictionary<string, string>
            {
                ["draft"] = "secondary",
                ["pending"] = "warning",
                ["confirmed"] = "primary",
                ["checked_in"] = "success",
                ["checked_out"] = "info",
                ["cancelled"] = "danger",
                ["no_show"] = "dark"
            };
    var color = statusColors.GetValueOrDefault(Model.Status, "secondary");
}

<div style="text-align:left; font-size:.92rem;">

    @* ── Encabezado: Folio + Estado ── *@
    <div class="d-flex align-items-center justify-content-between mb-3 pb-2 border-bottom">
        <div>
            <span style="font-size:1.4rem; font-weight:700; color:var(--primary);">@Model.Folio</span>
            @if (Model.GuestIsVip)
            {
                <span class="badge bg-warning text-dark ms-2"><i class="fas fa-star"></i> VIP</span>
            }
        </div>
        <span class="badge bg-@color" style="font-size:.85rem; padding:.4rem .75rem;">@Model.StatusLabel</span>
    </div>

    <div class="row g-3">

        @* ── Huésped ── *@
        <div class="col-md-6">
            <div class="fw-semibold text-muted mb-1" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
                <i class="fas fa-user me-1"></i>Huésped
            </div>
            <div class="fw-semibold">@Model.GuestFullName</div>
            @if (!string.IsNullOrEmpty(Model.GuestPhone))
            {
                <div class="text-muted small"><i class="fas fa-phone me-1"></i>@Model.GuestPhone</div>
            }
            @if (!string.IsNullOrEmpty(Model.GuestEmail))
            {
                <div class="text-muted small"><i class="fas fa-envelope me-1"></i>@Model.GuestEmail</div>
            }
        </div>

        @* ── Canal ── *@
        <div class="col-md-6">
            <div class="fw-semibold text-muted mb-1" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
                <i class="fas fa-satellite-dish me-1"></i>Canal
            </div>
            <span class="badge" style="background:var(--primary);color:#fff;">@Model.SourceLabel</span>
            @if (!string.IsNullOrEmpty(Model.TravelReasonLabel))
            {
                <div class="text-muted small mt-1"><i class="fas fa-suitcase me-1"></i>@Model.TravelReasonLabel</div>
            }
        </div>

        @* ── Fechas ── *@
        <div class="col-md-4">
            <div class="fw-semibold text-muted mb-1" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
                <i class="fas fa-sign-in-alt text-success me-1"></i>Check-in
            </div>
            <div class="fw-semibold">@Model.CheckInDate.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="col-md-4">
            <div class="fw-semibold text-muted mb-1" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
                <i class="fas fa-sign-out-alt text-danger me-1"></i>Check-out
            </div>
            <div class="fw-semibold">@Model.CheckOutDate.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="col-md-4">
            <div class="fw-semibold text-muted mb-1" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
                <i class="fas fa-moon me-1"></i>Noches
            </div>
            <div class="fw-semibold">@Model.NumNights</div>
        </div>

        @* ── Huéspedes ── *@
        <div class="col-12">
            <div class="fw-semibold text-muted mb-1" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
                <i class="fas fa-users me-1"></i>Huéspedes
            </div>
            <span class="me-3">@Model.TotalAdults adulto@(Model.TotalAdults != 1 ? "s" : "")</span>
            @if (Model.TotalChildren > 0)
            {
                <span class="me-3">@Model.TotalChildren niño@(Model.TotalChildren != 1 ? "s" : "")</span>
            }
            @if (Model.TotalBabies > 0)
            {
                <span class="me-3">@Model.TotalBabies bebé@(Model.TotalBabies != 1 ? "s" : "")</span>
            }
        </div>

        @* ── Habitaciones ── *@
        @if (Model.Rooms?.Any() == true)
        {
            <div class="col-12">
                <div class="fw-semibold text-muted mb-2" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
                    <i class="fas fa-bed me-1"></i>Habitaciones (@Model.Rooms.Count)
                </div>
                @foreach (var room in Model.Rooms)
                {
                    <div class="d-flex align-items-center gap-2 p-2 rounded border mb-1"
                         style="background:var(--bg-secondary);">
                        <span class="badge" style="background:var(--tertiary);color:#fff;">@room.RoomTypeCode</span>
                        <span class="fw-semibold">Hab. @room.RoomNumber</span>
                        @if (room.Floor.HasValue)
                        {
                            <span class="text-muted small">Piso @room.Floor</span>
                        }
                        <span class="ms-auto text-muted small">$@room.PricePerNight.ToString("N2")/noche</span>
                        <span class="fw-semibold" style="color:var(--primary);">$@room.Subtotal.ToString("N2")</span>
                    </div>
                }
            </div>
        }

        @* ── Financiero ── *@
        <div class="col-12">
            <div style="background:var(--bg-tertiary); border-radius:6px; padding:.85rem 1rem;">
                <div class="d-flex justify-content-between py-1 small">
                    <span class="text-muted">Subtotal:</span>
                    <span>$@Model.Subtotal.ToString("N2")</span>
                </div>
                @if (Model.DiscountAmount > 0)
                {
                    <div class="d-flex justify-content-between py-1 small">
                        <span class="text-muted">Descuento (@Model.DiscountPercent.ToString("G29")%):</span>
                        <span class="text-danger">-$@Model.DiscountAmount.ToString("N2")</span>
                    </div>
                }
                @if (Model.TaxesAmount > 0)
                {
                    <div class="d-flex justify-content-between py-1 small">
                        <span class="text-muted">Impuestos:</span>
                        <span>$@Model.TaxesAmount.ToString("N2")</span>
                    </div>
                }
                <div class="d-flex justify-content-between pt-2 mt-1 border-top fw-bold"
                     style="font-size:1rem; color:var(--primary);">
                    <span>TOTAL:</span>
                    <span>$@Model.Total.ToString("N2")</span>
                </div>
            </div>
        </div>

        @* ── Anticipo ── *@
        <div class="col-12">
            <div class="fw-semibold text-muted mb-1" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
                <i class="fas fa-dollar-sign me-1"></i>Anticipo
            </div>
            @if (Model.DepositAmount > 0)
            {
                <div class="d-flex gap-3 flex-wrap">
                    <span>
                        Monto: <strong style="color:var(--primary)">$@Model.DepositAmount.ToString("N2")</strong>
                    </span>
                    @if (Model.HasDeposit)
                    {
                        <span class="badge bg-success"><i class="fas fa-check me-1"></i>Pagado</span>
                        @if (Model.DepositPaymentMethod != null)
                        {
                            <span class="text-muted small">@Model.DepositPaymentMethod</span>
                        }
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pendiente</span>
                    }
                    <span>
                        Saldo: <strong class="text-warning">$@Model.BalancePending.ToString("N2")</strong>
                    </span>
                </div>
                @if (Model.DepositDueDate.HasValue)
                {
                    <div class="text-muted small mt-1">
                        <i class="fas fa-clock me-1"></i>Límite: @Model.DepositDueDate.Value.ToString("dd/MM/yyyy HH:mm")
                    </div>
                }
            }
            else
            {
                <span class="text-muted">Sin anticipo registrado</span>
            }
        </div>

        @* ── Notas ── *@
        @if (!string.IsNullOrEmpty(Model.GuestNotes))
        {
            <div class="col-12">
                <div class="fw-semibold text-muted mb-1" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
                    <i class="fas fa-comment me-1"></i>Notas del huésped
                </div>
                <p class="mb-0 text-secondary" style="font-style:italic;">@Model.GuestNotes</p>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.InternalNotes))
        {
            <div class="col-12">
                <div class="fw-semibold text-muted mb-1" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
                    <i class="fas fa-lock me-1"></i>Notas internas
                </div>
                <p class="mb-0 text-secondary" style="font-style:italic;">@Model.InternalNotes</p>
            </div>
        }

    </div>

    @* ── Pie: Auditoría ── *@
    <div class="mt-3 pt-2 border-top text-muted" style="font-size:.78rem;">
        Creada: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
    </div>

</div>
