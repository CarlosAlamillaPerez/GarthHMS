@model GarthHMS.Core.DTOs.Reservation.ReservationDetailDto
@using System.Globalization
@{
    ViewData["Title"] = $"Check-In {Model.Folio}";
    var config = ViewBag.Config as GarthHMS.Core.DTOs.Reservation.ReservationFormConfigDto;
    var settings = ViewBag.Settings as GarthHMS.Core.DTOs.HotelSettings.HotelSettingsDto;

    var hasEmail = !string.IsNullOrWhiteSpace(Model.GuestEmail);
    var blockIfBalance = settings?.BlockCheckinIfBalance ?? false;
    var requireCompanions = config?.RequireCompanionDetails ?? false;
    var companionsOpt = config?.CompanionsOptional ?? true;
    var hasBalance = Model.BalancePending > 0;
    var culture = new CultureInfo("es-MX");
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h1 class="page-title">
                <i class="fas fa-key me-2" style="color:var(--success);"></i>Check-In
                <span class="ms-2 text-muted fw-normal fs-5">@Model.Folio</span>
                @if (Model.GuestIsVip)
                {
                    <span class="badge ms-2" style="background:var(--warning);color:#fff;font-size:.7rem;">
                        <i class="fas fa-star me-1"></i>VIP
                    </span>
                }
            </h1>
            <p class="text-muted mb-0">
                @Model.GuestFullName &nbsp;·&nbsp;
                @Model.CheckInDate.ToLocalTime().ToString("dd MMM yyyy") →
                @Model.CheckOutDate.ToLocalTime().ToString("dd MMM yyyy") &nbsp;·&nbsp;
                @Model.NumNights noche@(Model.NumNights != 1 ? "s" : "")
            </p>
        </div>
        <div class="col-auto">
            <a href="/Reservations/Edit/@Model.ReservationId"
               class="btn btn-outline-secondary">
                <i class="fas fa-edit me-1"></i>Editar Reserva
            </a>
        </div>
    </div>
</div>

@* ── Bloqueo por saldo ── *@
@if (blockIfBalance && hasBalance)
{
    <div class="alert alert-danger d-flex align-items-center gap-3 mb-4">
        <i class="fas fa-ban fa-lg flex-shrink-0"></i>
        <div>
            <strong>No es posible realizar el check-in.</strong>
            El hotel requiere que el saldo esté liquidado antes del check-in.
            Saldo pendiente: <strong>@Model.BalancePending.ToString("C", culture)</strong>
        </div>
    </div>
}

<div class="row g-4">

    @* ══════════════════════════════════════════════════════
    COLUMNA IZQUIERDA — Resumen + Email + Vehículos + Acompañantes
    ══════════════════════════════════════════════════════ *@
    <div class="col-lg-7">

        @* ── Sección 1: Resumen de la reserva ── *@
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center"
                 style="background:var(--primary);color:#fff;cursor:pointer;"
                 onclick="toggleSection('sectionResumen', 'chevronResumen')">
                <span class="fw-semibold">
                    <i class="fas fa-calendar-alt me-2"></i>Resumen de la Reserva
                </span>
                <i class="fas fa-chevron-down" id="chevronResumen"
                   style="transition:transform .2s;"></i>
            </div>
            <div id="sectionResumen" class="card-body">
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <div class="text-muted small">Check-in</div>
                        <div class="fw-semibold">@Model.CheckInDate.ToLocalTime().ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="text-muted small">Check-out</div>
                        <div class="fw-semibold">@Model.CheckOutDate.ToLocalTime().ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="text-muted small">Noches</div>
                        <div class="fw-semibold">@Model.NumNights</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="text-muted small">Huéspedes</div>
                        <div class="fw-semibold">
                            @Model.TotalAdults adulto@(Model.TotalAdults != 1 ? "s" : "")
                            @if (Model.TotalChildren > 0)
                            {
                                <span class="text-muted"> · @Model.TotalChildren niño@(Model.TotalChildren != 1 ? "s" : "")</span>
                            }
                        </div>
                    </div>
                </div>

                @* Habitaciones *@
                <hr class="my-3">
                @foreach (var room in Model.Rooms)
                {
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div class="rounded d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:38px;height:38px;background:rgba(43,164,154,.12);">
                            <i class="fas fa-door-open" style="color:var(--primary);"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold">Hab. @room.RoomNumber — @room.RoomTypeName</div>
                            <div class="text-muted small">
                                @room.NumAdults adulto@(room.NumAdults != 1 ? "s" : "")
                                @if (room.NumChildren > 0)
                                {
                                    <span> · @room.NumChildren niño@(room.NumChildren != 1 ? "s" : "")</span>
                                }
                                @if (room.HasPets)
                                {
                                    <span> · <i class="fas fa-paw text-warning"></i> @room.NumPets mascota@(room.NumPets != 1 ? "s" : "")</span>
                                }
                            </div>
                        </div>
                        <div class="fw-semibold text-end">@room.PricePerNight.ToString("C", culture)<span class="text-muted fw-normal">/noche</span></div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.GuestNotes))
                {
                    <div class="alert alert-light border mt-2 py-2 small mb-0">
                        <i class="fas fa-comment-alt text-muted me-1"></i>
                        <strong>Nota del huésped:</strong> @Model.GuestNotes
                    </div>
                }
            </div>
        </div>

        @* ── Sección 2: Email ── *@
        <div class="card mb-4">
            <div class="card-header" style="background:rgba(43,164,154,.08);">
                <span class="fw-semibold">
                    <i class="fas fa-envelope me-2" style="color:var(--primary);"></i>Correo Electrónico
                </span>
            </div>
            <div class="card-body">
                @if (hasEmail)
                {
                    <div class="alert alert-info d-flex align-items-start gap-2 mb-2 py-2">
                        <i class="fas fa-paper-plane flex-shrink-0 mt-1"></i>
                        <div>
                            El comprobante de check-in se enviará a
                            <strong>@Model.GuestEmail</strong>
                        </div>
                    </div>
                    <div class="text-muted small">
                        <i class="fas fa-info-circle me-1"></i>
                        ¿Deseas enviarlo a otro correo?
                        <a href="/Guests/Edit/@Model.GuestId" target="_blank">
                            Actualiza el perfil del huésped
                        </a>
                        y vuelve a realizar el check-in.
                    </div>
                }
                else
                {
                    <div class="alert alert-warning d-flex align-items-center gap-2 py-2 mb-3">
                        <i class="fas fa-exclamation-triangle flex-shrink-0"></i>
                        <div>
                            <strong>Correo requerido.</strong>
                            El huésped no tiene correo registrado. Es necesario para enviar el comprobante.
                        </div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-semibold d-flex align-items-center justify-content-left">
                            Correo electrónico <span class="text-danger">*</span>
                        </label>
                        <input type="email" id="guestEmail" class="form-control"
                               placeholder="correo@ejemplo.com" maxlength="100" />
                        <div class="form-text">Se guardará en el perfil del huésped.</div>
                    </div>
                }
            </div>
        </div>

        @* ── Sección 3: Vehículos ── *@
        <div class="card mb-4">
            <div class="card-header" style="background:rgba(43,164,154,.08);">
                <span class="fw-semibold">
                    <i class="fas fa-car me-2" style="color:var(--primary);"></i>Vehículos
                    <span class="text-muted fw-normal fs-6 ms-1">(opcional)</span>
                </span>
            </div>
            <div class="card-body">
                @foreach (var room in Model.Rooms)
                {
                    <div class="mb-3">
                        <div class="text-muted small fw-semibold mb-1">
                            Hab. @room.RoomNumber — @room.RoomTypeName
                        </div>
                        <div class="d-flex gap-2">
                            <input type="text"
                                   class="form-control vehicle-plate-input"
                                   data-room-id="@room.RoomId"
                                   placeholder="Placas (ej: ABC-123)"
                                   value="@room.VehiclePlate"
                                   maxlength="15" />
                            <input type="text"
                                   class="form-control vehicle-desc-input"
                                   data-room-id="@room.RoomId"
                                   placeholder="Descripción (ej: Carro rojo)"
                                   value="@room.VehicleDescription"
                                   maxlength="100" />
                        </div>
                    </div>
                }
                <div class="text-muted small">
                    <i class="fas fa-info-circle me-1"></i>
                    Un vehículo máximo por habitación. Deja en blanco si no aplica.
                </div>
            </div>
        </div>

        @* ── Sección 4: Acompañantes (dinámico) ── *@
        @if (requireCompanions)
        {
            <div class="card mb-4">
                <div class="card-header" style="background:rgba(43,164,154,.08);">
                    <span class="fw-semibold">
                        <i class="fas fa-users me-2" style="color:var(--primary);"></i>Acompañantes
                        @if (companionsOpt)
                        {
                            <span class="text-muted fw-normal fs-6 ms-1">(opcional)</span>
                        }
                        else
                        {
                            <span class="text-danger fs-6 ms-1">*</span>
                        }
                    </span>
                </div>
                <div class="card-body" id="companionsSection">
                    @foreach (var room in Model.Rooms)
                    {
                        var adultSlots = Math.Max(0, room.NumAdults - 1);
                        var childrenSlots = room.NumChildren;
                        var totalSlots = adultSlots + childrenSlots;

                        if (totalSlots == 0) continue;

                        <div class="mb-4">
                            <div class="fw-semibold mb-2">
                                <i class="fas fa-door-open text-primary me-1"></i>
                                Hab. @room.RoomNumber — @room.RoomTypeName
                            </div>
                            <div class="companion-group"
                                 data-reservation-room-id="@room.ReservationRoomId">
                                @for (int i = 0; i < totalSlots; i++)
                                {
                                    var isChild = i >= adultSlots;
                                    var label = isChild ? $"Niño {i - adultSlots + 1}" : $"Acompañante {i + 1}";
                                    <div class="row g-2 mb-2 companion-row" data-index="@i">
                                        <div class="col-md-5">
                                            <input type="text"
                                                   class="form-control form-control-sm companion-name"
                                                   placeholder="@label — Nombre completo"
                                                   maxlength="100" />
                                        </div>
                                        <div class="col-md-2">
                                            <input type="number"
                                                   class="form-control form-control-sm companion-age"
                                                   placeholder="Edad" min="0" max="120" />
                                        </div>
                                        <div class="col-md-3">
                                            <input type="text"
                                                   class="form-control form-control-sm companion-phone"
                                                   placeholder="Teléfono" maxlength="20" />
                                        </div>
                                        <div class="col-md-2">
                                            <input type="text"
                                                   class="form-control form-control-sm companion-relationship"
                                                   placeholder="Relación" maxlength="30" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

    </div>

    @* ══════════════════════════════════════════════════════
    COLUMNA DERECHA — Estado financiero
    ══════════════════════════════════════════════════════ *@
    <div class="col-lg-5">
        <div class="card" style="position:sticky;top:1rem;">
            <div class="card-header" style="background:rgba(43,164,154,.08);">
                <span class="fw-semibold">
                    <i class="fas fa-dollar-sign me-2" style="color:var(--success);"></i>Estado Financiero
                </span>
            </div>
            <div class="card-body">

                @* Desglose *@
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Subtotal</span>
                    <span>@Model.Subtotal.ToString("C", culture)</span>
                </div>
                @if (Model.DiscountAmount > 0)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Descuento</span>
                        <span class="text-success">-@Model.DiscountAmount.ToString("C", culture)</span>
                    </div>
                }
                @if (Model.TaxesAmount > 0)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Impuestos</span>
                        <span>@Model.TaxesAmount.ToString("C", culture)</span>
                    </div>
                }
                <hr class="my-2">
                <div class="d-flex justify-content-between mb-2 fw-bold fs-5">
                    <span>Total</span>
                    <span>@Model.Total.ToString("C", culture)</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Pagado</span>
                    <span class="text-success fw-semibold">
                        @((Model.Total - Model.BalancePending).ToString("C", culture))
                    </span>
                </div>

                @* Saldo pendiente *@
                @if (hasBalance)
                {
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Saldo pendiente</span>
                        <span class="text-danger fw-bold fs-5">
                            @Model.BalancePending.ToString("C", culture)
                        </span>
                    </div>
                    <button type="button" class="btn btn-outline-primary w-100 mb-3"
                            onclick="openPaymentModal('@Model.ReservationId')">
                        <i class="fas fa-plus-circle me-1"></i>Registrar pago
                    </button>
                }
                else
                {
                    <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3">
                        <i class="fas fa-check-circle flex-shrink-0"></i>
                        <div><strong>Liquidado</strong> — Sin saldo pendiente</div>
                    </div>
                }

                @* Historial de pagos *@
                @if (Model.Payments.Any())
                {
                    <div class="border-top pt-3 mt-1">
                        <div class="text-muted small fw-semibold mb-2">Historial de pagos</div>
                        @foreach (var pago in Model.Payments)
                        {
                            var methodLabel = pago.Method switch
                            {
                                "cash" => "Efectivo",
                                "transfer" => "Transferencia",
                                "card" => "Tarjeta",
                                _ => pago.Method
                            };
                            <div class="d-flex justify-content-between align-items-center mb-1 small">
                                <span class="text-muted">
                                    @pago.PaymentDate.ToLocalTime().ToString("dd MMM HH:mm") · @methodLabel
                                </span>
                                <span class="fw-semibold text-success">
                                    @pago.Amount.ToString("C", culture)
                                </span>
                            </div>
                        }
                    </div>
                }
            </div>

            @* ── Botón principal ── *@
            <div class="card-footer text-center py-3">
                @if (blockIfBalance && hasBalance)
                {
                    <button type="button" class="btn btn-secondary btn-lg w-75" disabled>
                        <i class="fas fa-ban me-2"></i>Check-In bloqueado
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-success btn-lg w-75"
                            id="btnConfirmCheckin"
                            onclick="confirmCheckin()">
                        <i class="fas fa-key me-2"></i>Confirmar Check-In
                    </button>
                }
            </div>
        </div>
    </div>

</div>

@* Modal de pagos (Componente 5 — reutilizado) *@
<div id="paymentModalContainer"></div>

@section Scripts {
    <script>
        window.CheckInData = {
            reservationId: '@Model.ReservationId',
            guestId:       '@Model.GuestId',
            hasEmail:      @(hasEmail ? "true" : "false"),
            blockIfBalance: @(blockIfBalance ? "true" : "false"),
            requireCompanions: @(requireCompanions ? "true" : "false"),
            companionsOptional: @(companionsOpt ? "true" : "false"),
            folio: '@Model.Folio',
            guestName: '@Model.GuestFullName'
        };
    </script>
    <script src="~/js/reservations/checkin.js" asp-append-version="true"></script>
}