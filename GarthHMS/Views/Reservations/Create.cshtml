@* GarthHMS.Web/Views/Reservations/Index.cshtml *@
@{

    <div class="page-header d-flex align-items-center justify-content-between">

        <!-- Lado izquierdo: botón + título -->
        <div class="d-flex align-items-center gap-2">

            <a href="/Availability" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left"></i>
            </a>

            <h4 class="mb-0 fw-bold">
                @if (ViewBag.IsEdit == true)
                {
                    var res = ViewBag.Reservation as GarthHMS.Core.DTOs.Reservation.ReservationDetailDto;
                    <i class="fas fa-edit text-warning me-2"></i>
                    @($"Editando {res?.Folio}")
                }
                else
                {
                    <i class="fas fa-calendar-plus text-primary me-2"></i>
                    @("Nueva Reserva")
                }
            </h4>

        </div>

    </div>
    Layout = "~/Views/Shared/_Layout.cshtml";

    var config = ViewBag.Config as GarthHMS.Core.DTOs.Reservation.ReservationFormConfigDto
                 ?? new GarthHMS.Core.DTOs.Reservation.ReservationFormConfigDto();
    var operationMode = ViewBag.OperationMode as string ?? "hotel";
}

<style>
    /* ─── Secciones del formulario ────────────────────────────────────────── */
    .res-section {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 10px;
        margin-bottom: 1.5rem;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
    }

    .res-section-header {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .85rem 1.25rem;
        background: var(--bg-tertiary);
        border-bottom: 1px solid var(--border-color);
        font-weight: 600;
        font-size: .95rem;
        color: var(--text-primary);
    }

    .res-section-header .section-icon {
        width: 28px; height: 28px;
        border-radius: 6px;
        display: flex; align-items: center; justify-content: center;
        font-size: .85rem;
        flex-shrink: 0;
    }

    .res-section-body { padding: 1.25rem; }

    /* ─── Panel huésped seleccionado ──────────────────────────────────────── */
    #guestSelectedCard {
        display: none;
        align-items: center;
        gap: 1rem;
        padding: .9rem 1rem;
        background: rgba(43,164,154,.07);
        border: 1.5px solid var(--primary);
        border-radius: 8px;
        margin-bottom: 1rem;
    }

    #guestSelectedCard .guest-avatar {
        width: 42px; height: 42px;
        border-radius: 50%;
        background: var(--primary);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 1.1rem;
        flex-shrink: 0;
    }

    #guestSelectedCard .guest-info { flex: 1; }
    #guestSelectedCard .guest-name { font-weight: 600; font-size: 1rem; color: var(--text-primary); }
    #guestSelectedCard .guest-meta { font-size: .82rem; color: var(--text-secondary); }

    /* ─── Tabla de habitaciones agregadas ─────────────────────────────────── */
    .rooms-added-table th { background: var(--secondary); font-size: .82rem; }
    .rooms-added-table td { font-size: .88rem; vertical-align: middle; }
    .room-type-badge-sm {
        display: inline-block;
        padding: .2rem .55rem;
        background: var(--tertiary);
        color: #fff;
        border-radius: 4px;
        font-size: .78rem;
        font-weight: 500;
    }

    /* ─── Calculadora de precios ──────────────────────────────────────────── */
    .price-box {
        background: var(--bg-tertiary);
        border-radius: 8px;
        padding: 1rem 1.25rem;
        margin-top: 1rem;
    }

    .price-line {
        display: flex;
        justify-content: space-between;
        padding: .35rem 0;
        font-size: .9rem;
    }

    .price-line.divider { border-top: 1px solid var(--border-color); margin-top: .4rem; padding-top: .75rem; }
    .price-line.total-line {
        border-top: 2px solid var(--border-color);
        margin-top: .4rem;
        padding-top: .75rem;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--primary);
    }

    /* ─── Barra sticky de acciones ────────────────────────────────────────── */
    .res-actions-bar {
        position: sticky;
        bottom: 0;
        left: 0; right: 0;
        z-index: 90;
        background: var(--bg-card);
        border-top: 1px solid var(--border-color);
        padding: .9rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 -2px 8px rgba(0,0,0,.08);
        border-radius: 0 0 10px 10px;
    }

    /* ─── Número incrementador ────────────────────────────────────────────── */
    .num-ctrl {
        display: flex; align-items: center; gap: .4rem;
    }

    .num-ctrl button {
        width: 30px; height: 30px;
        border-radius: 5px;
        border: 1px solid var(--border-color);
        background: var(--bg-tertiary);
        color: var(--text-primary);
        font-size: 1rem;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: .15s;
    }

    .num-ctrl button:hover { background: var(--primary); color: #fff; border-color: var(--primary); }
    .num-ctrl input { width: 52px; text-align: center; font-weight: 600; }

    /* ─── Room selector modal ─────────────────────────────────────────────── */
    .room-type-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: .75rem;
        margin-bottom: 1.25rem;
    }

    .room-type-card-sel {
        border: 2px solid var(--border-color);
        border-radius: 8px;
        padding: 1rem;
        cursor: pointer;
        text-align: center;
        transition: .15s;
    }

    .room-type-card-sel:hover,
    .room-type-card-sel.selected { border-color: var(--primary); background: rgba(43,164,154,.07); }
    .room-type-card-sel .rt-name { font-weight: 600; font-size: .95rem; }
    .room-type-card-sel .rt-price { color: var(--primary); font-weight: 600; font-size: .9rem; margin-top: .25rem; }
    .room-type-card-sel .rt-avail { font-size: .78rem; color: var(--text-secondary); margin-top: .2rem; }

    .rooms-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: .6rem;
    }

    .room-card-sel {
        border: 2px solid var(--border-color);
        border-radius: 8px;
        padding: .65rem .5rem;
        cursor: pointer;
        text-align: center;
        transition: .15s;
    }

    .room-card-sel:hover:not(.occupied),
    .room-card-sel.selected { border-color: var(--primary); background: rgba(43,164,154,.07); }
    .room-card-sel.occupied { opacity: .45; cursor: not-allowed; background: var(--bg-tertiary); }
    .room-card-sel .rc-num { font-size: 1.2rem; font-weight: 700; color: var(--primary); }
    .room-card-sel .rc-floor { font-size: .75rem; color: var(--text-secondary); }
    .room-card-sel .rc-status {
        display: inline-block; margin-top: .25rem;
        padding: .1rem .4rem; border-radius: 3px;
        font-size: .7rem; font-weight: 600; color: #fff;
    }

    .rc-status.available { background: var(--success); }
    .rc-status.occupied  { background: var(--danger); }

    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* ─── Tarjetas de estado de anticipo ─────────────────────────────────── */
    .deposit-state-card {
        display: block;
        padding: .85rem 1rem;
        border: 2px solid var(--border-color);
        border-radius: 8px;
        cursor: pointer;
        transition: .15s;
        background: var(--bg-card);
    }

        .deposit-state-card:hover {
            border-color: var(--primary);
            background: rgba(43,164,154,.04);
        }

        .deposit-state-card.active {
            border-color: var(--primary);
            background: rgba(43,164,154,.07);
        }

    .deposit-state-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: .9rem;
    }
    /* ─── Mini cards de huéspedes ────────────────────────────────────────── */
    .guest-summary-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: .75rem 1.25rem;
        border-radius: 10px;
        min-width: 90px;
        border: 1.5px solid transparent;
        transition: .2s;
    }

    .guest-card-icon {
        font-size: 1.4rem;
        margin-bottom: .3rem;
    }

    .guest-card-count {
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1;
    }

    .guest-card-label {
        font-size: .75rem;
        margin-top: .25rem;
        font-weight: 500;
    }

    /* Adultos */
    .guest-card-adults {
        background: rgba(var(--primary-rgb, 43,164,154), .1);
        border-color: rgba(var(--primary-rgb, 43,164,154), .25);
    }

        .guest-card-adults .guest-card-icon,
        .guest-card-adults .guest-card-count {
            color: var(--primary);
        }

        .guest-card-adults .guest-card-label {
            color: var(--text-secondary);
        }

    /* Niños */
    .guest-card-children {
        background: rgba(255, 193, 7, .12);
        border-color: rgba(255, 193, 7, .3);
    }

        .guest-card-children .guest-card-icon,
        .guest-card-children .guest-card-count {
            color: #d4a017;
        }

        .guest-card-children .guest-card-label {
            color: var(--text-secondary);
        }

    /* Bebés */
    .guest-card-babies {
        background: rgba(13, 202, 240, .1);
        border-color: rgba(13, 202, 240, .25);
    }

        .guest-card-babies .guest-card-icon,
        .guest-card-babies .guest-card-count {
            color: #0dcaf0;
        }

        .guest-card-babies .guest-card-label {
            color: var(--text-secondary);
        }

    /* Dark mode automático via CSS variables del sistema */
    [data-theme="dark"] .guest-card-adults {
        background: rgba(43,164,154,.15);
        border-color: rgba(43,164,154,.3);
    }

    [data-theme="dark"] .guest-card-children {
        background: rgba(255,193,7,.12);
        border-color: rgba(255,193,7,.25);
    }

    [data-theme="dark"] .guest-card-babies {
        background: rgba(13,202,240,.1);
        border-color: rgba(13,202,240,.2);
    }

    /* ─── KPI Factura ─────────────────────────────────────────────────────── */
    .invoice-kpi-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: .9rem 1.25rem;
        border: 2px solid var(--border-color);
        border-radius: 10px;
        cursor: pointer;
        transition: .2s;
        background: var(--bg-card);
        user-select: none;
    }

        .invoice-kpi-card:hover {
            border-color: var(--primary);
        }

        .invoice-kpi-card.active {
            border-color: var(--primary);
            background: rgba(43,164,154,.08);
        }

    .invoice-kpi-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background: rgba(43,164,154,.12);
        color: var(--primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
        transition: .2s;
    }

    .invoice-kpi-card.active .invoice-kpi-icon {
        background: var(--primary);
        color: #fff;
    }

    .invoice-kpi-text {
        flex: 1;
    }
    
</style>

<div class="main-content" style="max-width: 920px; margin: 0 auto; padding-bottom: 120px;">

    @* ──────────────────────────────────────────────────────────────────────── *@
    @* SECCIÓN 1: INFORMACIÓN DEL HUÉSPED *@
    @* ──────────────────────────────────────────────────────────────────────── *@
    <div class="res-section">
        <div class="res-section-header">
            <div class="section-icon bg-primary text-white"><i class="fas fa-user"></i></div>
            <span>Información del Huésped</span>
            <span class="badge bg-danger ms-1" style="font-size:.7rem">Requerido</span>
        </div>
        <div class="res-section-body">

            @* ── Huésped seleccionado ── *@
            <div id="guestSelectedCard">
                <div class="guest-avatar" id="guestInitials">?</div>
                <div class="guest-info">
                    <div class="guest-name" id="guestSelectedName">—</div>
                    <div class="guest-meta">
                        <span id="guestSelectedPhone"></span>
                        <span id="guestSelectedEmail" class="ms-2"></span>
                        <span id="guestVipBadge" class="badge bg-warning text-dark ms-2" style="display:none">
                            <i class="fas fa-star"></i> VIP
                        </span>
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearGuest()">
                    <i class="fas fa-times"></i> Cambiar
                </button>
            </div>

            @* ── Buscador — solo en CREAR ── *@
            @if (ViewBag.IsEdit != true)
            {
                @* ── Acciones de búsqueda ── *@
                <div id="guestSearchArea">
                    <div class="row g-2">
                        <div class="col-md-8">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-search"></i></span>
                                <input type="text"
                                       id="guestQuickSearch"
                                       class="form-control"
                                       placeholder="Buscar huésped por nombre, teléfono o email..."
                                       oninput="onGuestQuickSearch(this.value)" />
                            </div>
                        </div>
                        <div class="col-md-4 d-flex gap-2">
                            <button type="button" class="btn btn-primary flex-fill" onclick="openGuestSearchModal()">
                                <i class="fas fa-search"></i> Buscar huésped
                            </button>
                            <button type="button" class="btn btn-outline-primary" onclick="openCreateGuestModal()" title="Crear nuevo huésped">
                                <i class="fas fa-user-plus"></i>
                            </button>
                        </div>
                    </div>

                    @* Quick results dropdown *@
                    <div id="guestQuickResults" class="border rounded mt-1" style="display:none; max-height:200px; overflow-y:auto; background: var(--bg-card);">
                    </div>
                </div>
            }


            @* Campo oculto con el GuestId seleccionado *@
            <input type="hidden" id="selectedGuestId" />

        </div>
    </div>

    @* ── KPI Factura (solo si hotel puede facturar) ── *@
    @if (config.CanInvoice)
    {
        <div class="col-12 mb-3">
            <div id="invoiceKpi" class="invoice-kpi-card" onclick="toggleInvoice()">
                <div class="invoice-kpi-icon">
                    <i class="fas fa-file-invoice"></i>
                </div>
                <div class="invoice-kpi-text">
                    <div class="fw-semibold">Requiere Factura</div>
                    <small id="invoiceKpiSub" class="text-muted">Clic para activar</small>
                </div>
                <div class="invoice-kpi-toggle">
                    <i id="invoiceKpiCheck" class="fas fa-toggle-off fa-2x text-muted"></i>
                </div>
            </div>

            <div id="invoiceBillingInfo" style="display:none;" class="mt-2 p-3 rounded border border-primary-subtle bg-primary-subtle small">
                <i class="fas fa-info-circle text-primary me-1"></i>
                <span id="invoiceBillingText"></span>
            </div>
        </div>
    }

    @* ──────────────────────────────────────────────────────────────────────── *@
    @* SECCIÓN 2: DETALLES DE LA RESERVA *@
    @* ──────────────────────────────────────────────────────────────────────── *@
    <div class="res-section">
        <div class="res-section-header">
            <div class="section-icon bg-primary text-white"><i class="fas fa-calendar-alt"></i></div>
            <span>Detalles de la Reserva</span>
        </div>
        <div class="res-section-body">

            @* ── Canal de reserva ── *@
            <div class="mb-3">
                <label class="d-flex align-items-center justify-content-center justify-content-md-start">
                    <i class="fas fa-satellite-dish text-primary me-1"></i>Canal de reserva <span class="text-danger">*</span>
                </label>
                <div class="d-flex flex-wrap gap-2" id="sourceRadioGroup">
                    @foreach (var (val, lbl, icon) in new[] {
                    ("whatsapp",    "WhatsApp",   "fab fa-whatsapp"),
                    ("direct",      "Directo",    "fas fa-handshake"),
                    ("walkin",      "Presencial", "fas fa-walking"),
                    ("booking",     "Booking.com","fas fa-globe"),
                    ("airbnb",      "Airbnb",     "fab fa-airbnb"),
                    ("expedia",     "Expedia",    "fas fa-plane"),
                    ("other",       "Otro",       "fas fa-ellipsis-h"),
                    })
                    {
                        <label class="source-btn d-flex align-items-center gap-1 px-3 py-2 rounded border cursor-pointer"
                               style="cursor:pointer; font-size:.88rem; transition:.15s;"
                               data-value="@val">
                            <input type="radio" name="source" value="@val" class="d-none" @(val == "whatsapp" ? "checked" : "")>
                            <i class="@icon"></i> @lbl
                        </label>
                    }
                </div>
            </div>

            @* ── Fechas ── *@
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="d-flex align-items-center justify-content-center justify-content-md-start">
                        <i class="fas fa-sign-in-alt text-success me-1"></i>Check-in <span class="text-danger">*</span>
                    </label>
                    <input type="date" id="checkInDate" class="form-control" onchange="onDatesChange()" />
                </div>
                <div class="col-md-4">
                    <label class="d-flex align-items-center justify-content-center justify-content-md-start">
                        <i class="fas fa-sign-out-alt text-danger me-1"></i>Check-out <span class="text-danger">*</span>
                    </label>
                    <input type="date" id="checkOutDate" class="form-control" onchange="onDatesChange()" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-moon text-primary me-1"></i>Noches
                    </label>
                    <div class="form-control text-center fw-bold text-primary" id="nightsDisplay">—</div>
                </div>
            </div>

            @* ── Huéspedes (calculado automáticamente al agregar habitaciones) ── *@
            <div class="mb-3">
                <label class="form-label fw-semibold d-block mb-2">
                    <i class="fas fa-users text-primary me-1"></i>Huéspedes
                </label>

                @* Mini cards visibles *@
                <div id="guestSummaryCards" class="d-flex flex-wrap justify-content-center gap-3 mb-2">

                    @* Adultos — siempre visible *@
                    <div class="guest-summary-card guest-card-adults">
                        <div class="guest-card-icon">
                            <i class="fas fa-user-tie"></i>
                        </div>
                        <div class="guest-card-count" id="displayAdults">0</div>
                        <div class="guest-card-label">Adultos</div>
                    </div>

                    @* Niños — solo visible si > 0 *@
                    <div class="guest-summary-card guest-card-children" id="cardChildren" style="display:none;">
                        <div class="guest-card-icon">
                            <i class="fas fa-child"></i>
                        </div>
                        <div class="guest-card-count" id="displayChildren">0</div>
                        <div class="guest-card-label">Niños</div>
                    </div>

                    @* Bebés — solo visible si > 0 *@
                    <div class="guest-summary-card guest-card-babies" id="cardBabies" style="display:none;">
                        <div class="guest-card-icon">
                            <i class="fas fa-baby"></i>
                        </div>
                        <div class="guest-card-count" id="displayBabies">0</div>
                        <div class="guest-card-label">Bebés</div>
                    </div>

                </div>

                <p class="text-center text-muted small mb-0">
                    <i class="fas fa-info-circle me-1"></i>
                    Se calcula automáticamente al agregar habitaciones
                </p>

                @* Inputs ocultos — escritos por JS *@
                <input type="hidden" id="totalAdults" value="0" />
                <input type="hidden" id="totalChildren" value="0" />
                <input type="hidden" id="totalBabies" value="0" />
            </div>



            @* ── Servicios adicionales ── *@
            <div class="row g-3">
                @* Mascotas *@
                <div class="col-md-6">
                    <label class="form-label fw-semibold"><i class="fas fa-paw text-warning me-1"></i>Mascotas</label>
                    <div class="d-flex align-items-center gap-3">
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" id="hasPets"
                                   onchange="togglePets(this.checked)" role="switch">
                            <label class="form-check-label" for="hasPets">¿Trae mascotas?</label>
                        </div>
                        <div id="petsCountArea" style="display:none;">
                            <div class="num-ctrl">
                                <button type="button" onclick="changePets(-1)">−</button>
                                <input type="number" id="petsCount" value="1" min="1"
                                       max="@config.MaxPetsPerRoom" class="form-control" style="width:52px; text-align:center; font-weight:600;" />
                                <button type="button" onclick="changePets(1)">+</button>
                            </div>
                            <small class="text-muted ms-1">máx. @config.MaxPetsPerRoom</small>
                        </div>
                    </div>
                </div>
                <div class="col-12" id="petsConflictWrapper" style="display:none;">
                    <div class="alert alert-danger d-flex align-items-start gap-2 py-2 mb-0"
                         style="font-size:0.83rem;">
                        <i class="fas fa-ban flex-shrink-0 mt-1"></i>
                        <div id="petsConflictMsg"></div>
                    </div>
                </div>

                @* Estacionamiento *@
                @if (config.HasParking)
                {
                    <div class="col-md-6">
                        <label class="form-label fw-semibold"><i class="fas fa-car text-secondary me-1"></i>Estacionamiento</label>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="needsParking" role="switch">
                            <label class="form-check-label" for="needsParking">¿Necesita estacionamiento?</label>
                        </div>
                        @if (config.ParkingCapacity > 0)
                        {
                            <small class="text-muted">Capacidad total: @config.ParkingCapacity cajones</small>
                        }
                    </div>
                }

                @* Motivo del viaje *@
                <div class="col-md-6">
                    <label class="form-label fw-semibold"><i class="fas fa-suitcase text-primary me-1"></i>Motivo del viaje</label>
                    <select id="travelReason" class="form-select">
                        <option value="">Sin especificar</option>
                        <option value="leisure">Placer / Turismo</option>
                        <option value="business">Negocios</option>
                        <option value="event">Evento</option>
                        <option value="other">Otro</option>
                    </select>
                </div>
            </div>

        </div>
    </div>

    @* ──────────────────────────────────────────────────────────────────────── *@
    @* SECCIÓN 3: HABITACIONES Y PRECIOS *@
    @* ──────────────────────────────────────────────────────────────────────── *@
    <div class="res-section">
        <div class="res-section-header">
            <div class="section-icon bg-primary text-white"><i class="fas fa-bed"></i></div>
            <span>Habitaciones y Precios</span>
            <span id="roomsBadge" class="badge bg-secondary ms-auto" style="font-size:.72rem">Sin habitaciones</span>
        </div>
        <div class="res-section-body">

            @* Tabla de habitaciones agregadas *@
            <div class="table-responsive mb-3">
                <table class="table table-sm rooms-added-table mb-0" id="roomsAddedTable">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>Habitación</th>
                            <th>Piso</th>
                            <th>Adultos</th>
                            <th>Precio/Noche</th>
                            <th>Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="roomsAddedBody">
                        <tr id="emptyRoomsRow">
                            <td colspan="7" class="text-center py-4 text-muted">
                                <i class="fas fa-bed fa-2x mb-2 d-block opacity-25"></i>
                                No hay habitaciones — haz clic en <strong>Agregar Habitación</strong>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <button type="button" class="btn btn-primary" onclick="openRoomSelector()">
                <i class="fas fa-plus"></i> Agregar Habitación
            </button>

            @* ── Calculadora de precios ── *@
            <div class="price-box" id="priceBox" style="display:none">
                <div class="price-line">
                    <span class="text-secondary">Precio base:</span>
                    <span id="priceBase" class="fw-semibold">$0</span>
                </div>

                @* Descuento *@
                <div class="price-line">
                    <span class="text-secondary">Descuento:</span>
                    <div class="d-flex gap-2 align-items-center">
                        <select id="discountType" class="form-select form-select-sm" style="width:160px" onchange="onDiscountChange()">
                            <option value="0">Sin descuento</option>
                            <option value="5">5%</option>
                            <option value="10">10%</option>
                            <option value="15">15%</option>
                            <option value="20">20%</option>
                            <option value="custom">Personalizado</option>
                        </select>
                        <input type="number" id="discountCustom" class="form-control form-control-sm" style="width:80px; display:none;"
                               placeholder="%" min="0" max="100" oninput="recalculate()" />
                    </div>
                </div>
                <div class="price-line">
                    <span class="text-secondary">Monto descuento:</span>
                    <span id="priceDiscount" class="fw-semibold text-danger">-$0</span>
                </div>

                @* Impuestos *@
                @if (config.ChargesTaxes)
                {
                    <div class="price-line divider">
                        <span class="text-secondary">IVA (@config.TaxIvaPercent%):</span>
                        <span id="priceTaxIva" class="fw-semibold">$0</span>
                    </div>
                    <div class="price-line">
                        <span class="text-secondary">ISH (@config.TaxIshPercent%):</span>
                        <span id="priceTaxIsh" class="fw-semibold">$0</span>
                    </div>
                }

                <div class="price-line total-line">
                    <span>TOTAL A PAGAR:</span>
                    <span id="priceTotal">$0</span>
                </div>
            </div>

        </div>
    </div>

    @* ── Sección Acompañantes (solo si el hotel lo requiere) ── *@
    @if (config.RequireCompanionDetails)
    {
        <div class="section-card mb-3" id="companionsSection">
            <div class="section-header @(config.CompanionsOptional ? "bg-info" : "bg-primary")">
                <i class="fas fa-users"></i>
                Acompañantes
                @if (config.CompanionsOptional)
                {
                    <span class="badge bg-white text-info ms-2" style="font-size:.75rem;">Opcional</span>
                }
                else
                {
                    <span class="badge bg-white text-primary ms-2" style="font-size:.75rem;">Requerido</span>
                }
            </div>
            <div class="section-body">
                <div id="companionsContainer">
                    <div class="text-muted text-center py-3">
                        <i class="fas fa-bed me-2"></i>
                        Agrega habitaciones para ver los campos de acompañantes
                    </div>
                </div>
            </div>
        </div>
    }

    @* ──────────────────────────────────────────────────────────────────────── *@
    @* SECCIÓN 4: ANTICIPO Y PAGO *@
    @* ──────────────────────────────────────────────────────────────────────── *@
    <div class="res-section">
        <div class="res-section-header">
            <div class="section-icon bg-primary text-white"><i class="fas fa-dollar-sign"></i></div>
            <span>Anticipo y Pago</span>
        </div>
        <div class="res-section-body" id="depositSection">

            @* ── Caso plataforma OTA (se muestra automáticamente según canal) ── *@
            <div id="depositPlatformMsg" style="display:none;">
                <div class="alert alert-info d-flex align-items-start gap-3 mb-0">
                    <i class="fas fa-info-circle fa-lg mt-1 text-info"></i>
                    <div>
                        <strong>Pago gestionado por la plataforma</strong>
                        <p class="mb-1 mt-1 small">
                            El cobro es responsabilidad de Booking.com / Airbnb.
                            Se generará una alerta para que el gerente verifique la reserva en la plataforma.
                        </p>
                    </div>
                </div>
            </div>

            @* ── Caso canales directos ── *@
            <div id="depositDirectSection">

                <label class="form-label fw-semibold mb-3">Estado del anticipo</label>

                <div class="d-flex flex-column gap-2 mb-3" id="depositStateGroup">

                    @* Opción 1: Sin anticipo *@
                    <label class="deposit-state-card" id="cardDepositNone"
                           onclick="onDepositStateChange('none')">
                        <input type="radio" name="depositState" value="none" class="d-none">
                        <div class="d-flex align-items-center gap-3">
                            <div class="deposit-state-icon bg-secondary-subtle text-secondary">
                                <i class="fas fa-ban"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Sin anticipo requerido</div>
                                <small class="text-muted">La reserva quedará pendiente hasta el check-in</small>
                            </div>
                        </div>
                    </label>

                    @* Opción 2: Anticipo solicitado, aún no ha pagado *@
                    <label class="deposit-state-card" id="cardDepositPending"
                           onclick="onDepositStateChange('pending')">
                        <input type="radio" name="depositState" value="pending" class="d-none">
                        <div class="d-flex align-items-center gap-3">
                            <div class="deposit-state-icon bg-warning-subtle text-warning">
                                <i class="fas fa-clock"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Anticipo solicitado — aún no ha pagado</div>
                                <small class="text-muted">El huésped pagará después (WhatsApp, teléfono, etc.)</small>
                            </div>
                        </div>
                    </label>

                    @* Opción 3: Anticipo ya recibido *@
                    <label class="deposit-state-card active" id="cardDepositReceived"
                           onclick="onDepositStateChange('received')">
                        <input type="radio" name="depositState" value="received" class="d-none" checked>
                        <div class="d-flex align-items-center gap-3">
                            <div class="deposit-state-icon bg-success-subtle text-success">
                                <i class="fas fa-check-circle"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Anticipo ya recibido — registrar pago</div>
                                <small class="text-muted">El huésped pagó en este momento o acaba de transferir</small>
                            </div>
                        </div>
                    </label>

                </div>

                @* ── Detalles: "pending" — IDs sin sufijo (depositPct, depositFixed, depositCustomAmount) ── *@
                <div id="depositPendingDetails" style="display:none;" class="mt-3 pt-3 border-top">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-percentage text-primary me-1"></i>Porcentaje solicitado
                            </label>
                            <div class="d-flex gap-3 align-items-center">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="depositCalcTypeP"
                                           id="depositPct" value="pct" checked onchange="onDepositTypeChange()">
                                    <label class="form-check-label" for="depositPct">
                                        @config.MinDepositPercent% (<span id="depositPctAmountP">$0</span>)
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="depositCalcTypeP"
                                           id="depositFixed" value="fixed" onchange="onDepositTypeChange()">
                                    <label class="form-check-label" for="depositFixed">Monto fijo</label>
                                </div>
                            </div>
                            <input type="number" id="depositCustomAmount" class="form-control mt-2"
                                   placeholder="$0.00" min="0" style="display:none;" oninput="recalculate()" />
                            <small class="text-muted d-block mt-1">
                                Anticipo requerido: <strong id="depositBalanceP" class="text-warning">$0</strong>
                            </small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-calendar-times text-warning me-1"></i>Fecha límite de pago (opcional)
                            </label>
                            <input type="datetime-local" id="depositDueDateP" class="form-control" />
                            <small class="text-muted">Si no se recibe antes de esta fecha, la reserva puede cancelarse</small>
                        </div>
                    </div>
                </div>

                @* ── Detalles: "received" ── *@
                <div id="depositReceivedDetails" style="display:none;" class="mt-3 pt-3 border-top">

                    @* Splits de pago *@
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-hand-holding-usd text-success me-1"></i>
                            Pagos recibidos
                        </label>
                        <div id="paymentSplitsContainer">
                            @* Las filas se generan con JS *@
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-secondary mt-2"
                                onclick="addPaymentSplit()">
                            <i class="fas fa-plus me-1"></i>Agregar otro método de pago
                        </button>
                        <div class="form-text text-muted mt-1">
                            <i class="fas fa-info-circle me-1"></i>
                            Útil para pagos mixtos: una parte en efectivo y otra por transferencia.
                        </div>
                    </div>

                    @* Referencia solo aparece inline en cada split *@
                    <div id="depositReferenceArea" style="display:none;"></div>

                </div>

            </div>

        </div>
    </div>

    @* ──────────────────────────────────────────────────────────────────────── *@
    @* SECCIÓN 5: NOTAS Y OBSERVACIONES *@
    @* ──────────────────────────────────────────────────────────────────────── *@
    <div class="res-section">
        <div class="res-section-header">
            <div class="section-icon bg-secondary" style="color:var(--text-primary)"><i class="fas fa-sticky-note"></i></div>
            <span>Notas y Observaciones</span>
            <small class="ms-auto text-muted">(Opcional)</small>
        </div>
        <div class="res-section-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-comment text-primary me-1"></i>Peticiones del huésped
                    </label>
                    <textarea id="guestNotes" class="form-control" rows="3"
                              placeholder="Habitación en planta baja, cama extra, llegada tardía..."></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-lock text-secondary me-1"></i>Notas internas
                        <small class="text-muted">(No visibles para el huésped)</small>
                    </label>
                    <textarea id="internalNotes" class="form-control" rows="3"
                              placeholder="Cliente VIP, adeudo anterior, comportamiento especial..."></textarea>
                </div>
            </div>
        </div>

        @* ── Barra de acciones sticky ── *@
        <div class="res-actions-bar">
            <a href="/Availability" class="btn btn-outline-secondary">
                <i class="fas fa-times me-1"></i>Cancelar
            </a>
            <div class="d-flex gap-2">
                <button type="button" id="mainSubmitBtn" class="btn btn-success px-4"
                        onclick="handleMainSubmit()">
                    <i class="fas fa-save me-1"></i>Guardar borrador
                </button>
            </div>
        </div>

    </div>

</div>

@* ── Template del selector de habitaciones (renderizado en JS) ─────────────── *@
<script id="roomSelectorTpl" type="text/x-template">
    <div style="text-align:left;">
        <p class="text-muted small mb-3">
            <i class="fas fa-info-circle text-primary me-1"></i>
            Fechas: <strong id="selectorDates">—</strong>
        </p>

        <div id="selectorStep1">
            <p class="fw-semibold mb-2">Paso 1 — Selecciona el tipo de habitación:</p>
            <div class="room-type-grid" id="roomTypeGrid">
                <div class="text-center py-3 text-muted">
                    <i class="fas fa-spinner fa-spin"></i> Cargando tipos...
                </div>
            </div>
        </div>

        <div id="selectorStep2" style="display:none;">
            <button type="button" class="btn btn-sm btn-link ps-0 mb-2" onclick="backToStep1()">
                <i class="fas fa-arrow-left"></i> Cambiar tipo
            </button>
            <p class="fw-semibold mb-2">Paso 2 — Selecciona la habitación específica:</p>
            <div class="rooms-grid" id="roomsGrid">
                <div class="text-center py-3 text-muted col-span-4">
                    <i class="fas fa-spinner fa-spin"></i> Cargando habitaciones...
                </div>
            </div>
        </div>

         <div id="selectorStep3" style="display:none;">
            <button type="button" class="btn btn-sm btn-link ps-0 mb-3" onclick="backToStep2()">
                <i class="fas fa-arrow-left"></i> Cambiar habitación
            </button>

            <p id="step3RoomLabel" class="fw-semibold mb-3 text-primary"></p>

            <div class="row g-3">
                <div class="col-4">
                    <label class="form-label fw-semibold text-center d-block">
                        <i class="fas fa-user-tie text-primary me-1"></i>Adultos
                    </label>
                    <div class="num-ctrl justify-content-center">
                        <button type="button" onclick="changeStep3('step3Adults', -1)">−</button>
                        <input type="number" id="step3Adults" value="1" min="1" class="form-control"
                               style="width:52px; text-align:center; font-weight:600;" readonly />
                        <button type="button" onclick="changeStep3('step3Adults', 1)">+</button>
                    </div>
                </div>
                <div class="col-4">
                    <label class="form-label fw-semibold text-center d-block">
                        <i class="fas fa-child text-warning me-1"></i>Niños
                    </label>
                    <div class="num-ctrl justify-content-center">
                        <button type="button" onclick="changeStep3('step3Children', -1)">−</button>
                        <input type="number" id="step3Children" value="0" min="0" class="form-control"
                               style="width:52px; text-align:center; font-weight:600;" readonly />
                        <button type="button" onclick="changeStep3('step3Children', 1)">+</button>
                    </div>
                </div>
                <div class="col-4">
                    <label class="form-label fw-semibold text-center d-block">
                        <i class="fas fa-baby text-info me-1"></i>Bebés
                    </label>
                    <div class="num-ctrl justify-content-center">
                        <button type="button" onclick="changeStep3('step3Babies', -1)">−</button>
                        <input type="number" id="step3Babies" value="0" min="0" class="form-control"
                               style="width:52px; text-align:center; font-weight:600;" readonly />
                        <button type="button" onclick="changeStep3('step3Babies', 1)">+</button>
                    </div>
                </div>
            </div>

            <div class="mt-3 text-center">
                <small class="text-muted">Total personas: </small>
                <strong id="step3TotalPersons" style="color:var(--success)">1</strong>
            </div>
            <div class="mt-2 text-center small" id="step3PriceBreakdown"></div>
        </div>
    </div>
</script>

@section Scripts {
    <script>
        // Pasar configuración del hotel al JS
        window.HotelConfig = {
            chargesTaxes: @(config.ChargesTaxes ? "true" : "false"),
            taxIvaPercent: @config.TaxIvaPercent,
            taxIshPercent: @config.TaxIshPercent,
            minDepositPct: @config.MinDepositPercent,
            maxPetsPerRoom: @config.MaxPetsPerRoom,
            hasParking: @(config.HasParking ? "true" : "false"),
            operationMode: '@operationMode',
            requireCompanionDetails: @(config.RequireCompanionDetails ? "true" : "false"),
            companionsOptional: @(config.CompanionsOptional ? "true" : "false")
        };

        // — modo edición —
        window.IsEditMode = @((ViewBag.IsEdit == true ? "true" : "false"));
        window.EditReservation = @(ViewBag.IsEdit == true
        ? Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Reservation as GarthHMS.Core.DTOs.Reservation.ReservationDetailDto, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))
        : Html.Raw("null"));
    </script>
    <script src="~/js/reservations/reservations-create.js"></script>
}
